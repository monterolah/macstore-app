  const div=document.createElement('div');div.className='logo-row-item';
  div.style.cssText='display:grid;grid-template-columns:52px 1fr auto;gap:10px;align-items:center;margin-bottom:10px;padding:10px;background:#f5f5f7;border-radius:10px';
  div.innerHTML=`
    <div style="width:52px;height:52px;background:#fff;border-radius:8px;display:flex;align-items:center;justify-content:center;border:1px solid #e8e8ed" id="logoPrev_new"><span style="font-size:18px">🏷</span></div>
    <div style="display:flex;flex-direction:column;gap:5px">
      <input class="si logo-label" placeholder="Etiqueta">
      <input class="si logo-img-url" placeholder="URL del logo" oninput="updateLogoPreview(this)">
      <input class="si logo-link" placeholder="Link (opcional)">
    </div>
    <button type="button" class="sdel" onclick="this.closest('.logo-row-item').remove()">×</button>`;
