  if(url) prev.innerHTML=`<img src="${url}" style="max-width:46px;max-height:46px;object-fit:contain" onerror="this.style.display='none'">`;
  else prev.innerHTML='<span style="font-size:18px">🏷</span>';
}

// ── COLORES ───────────────────────────────────────────────────────────────
function addColor(){
  const list=document.getElementById('colorList');
  const div=document.createElement('div');
  div.className='color-variant-row';

  // Get current variants for capacity checkboxes
  const varLabels=[...document.querySelectorAll('.variant-label')].map(i=>i.value.trim()).filter(Boolean);
  const capsHTML = varLabels.length ? `
    <div style="background:#fff;border-radius:8px;padding:8px 10px;border:1px solid #e8e8ed;margin-top:10px">
      <label style="font-size:10px;color:#86868b;font-weight:600;display:block;margin-bottom:6px">CAPACIDADES EN ESTE COLOR</label>
      <div style="display:flex;flex-wrap:wrap;gap:6px">
        ${varLabels.map(v=>`<label style="display:flex;align-items:center;gap:5px;font-size:12px;cursor:pointer;background:#f5f5f7;padding:4px 10px;border-radius:6px">
          <input type="checkbox" class="color-cap-check" value="${v}" checked style="accent-color:#1d1d1f;width:13px;height:13px"> ${v}
        </label>`).join('')}
      </div>
    </div>` : '';

  div.innerHTML=`
    <div style="display:flex;gap:12px;align-items:flex-start;margin-bottom:10px">
      <div>
        <label style="font-size:10px;color:#86868b;display:block;margin-bottom:4px">Burbuja</label>
        <div class="color-swatch-preview" onclick="this.nextElementSibling.click()"><span style="font-size:18px;color:#86868b">+</span></div>
        <input type="file" accept="image/*" style="display:none" onchange="uploadSwatchImg(this)">
        <input type="hidden" class="color-swatch-url" value="">
      </div>
      <div style="flex:1;display:flex;flex-direction:column;gap:8px">
        <div>
          <label style="font-size:10px;color:#86868b;display:block;margin-bottom:2px">Nombre del color *</label>
          <input class="si color-name" placeholder="ej: Azul Titanio">
                <label style="display:flex;align-items:center;gap:6px;margin-top:6px;font-size:12px;color:#515154"><input type="checkbox" class="color-enabled" style="accent-color:#1d1d1f;width:14px;height:14px" checked> Color activo</label>
        </div>
        <div>
          <label style="font-size:10px;color:#86868b;display:block;margin-bottom:2px">Imagen del producto en este color</label>
          <input type="file" accept="image/*" class="color-prod-file" onchange="uploadProdImg(this)" style="font-size:11px;width:100%">
          <input class="si color-img-url" placeholder="O pega URL de imagen" style="margin-top:5px" oninput="updateColorImgPreview(this.closest('.color-variant-row'),this.value)">
        </div>
        <div class="color-img-preview-box" style="display:flex;gap:8px;align-items:center;background:#fff;border-radius:8px;padding:8px;border:1px solid #e8e8ed;margin-top:4px">
          <img src="" style="width:56px;height:56px;border-radius:6px;background:#f5f5f7;flex-shrink:0;object-fit:contain;object-position:center;transform:scale(1);transform-origin:center center">
          <div style="flex:1;display:grid;grid-template-columns:1fr 1fr;gap:6px">
            <div>
              <label style="font-size:10px;color:#86868b;display:block;margin-bottom:2px">Encuadre</label>
              <select class="si color-fit" style="font-size:12px;padding:4px 8px;width:100%" onchange="updateColorImgPreview(this.closest('.color-variant-row'), this.closest('.color-variant-row').querySelector('.color-img-url')?.value||'')"><option value="contain">Completa</option><option value="cover">Llenar</option></select>
            </div>
            <div>
              <label style="font-size:10px;color:#86868b;display:block;margin-bottom:2px">Posición</label>
              <select class="si color-pos" style="font-size:12px;padding:4px 8px;width:100%" onchange="updateColorImgPreview(this.closest('.color-variant-row'), this.closest('.color-variant-row').querySelector('.color-img-url')?.value||'')"><option value="center">Centro</option><option value="top">Arriba</option><option value="bottom">Abajo</option><option value="left">Izquierda</option><option value="right">Derecha</option></select>
            </div>
            <div style="grid-column:1 / -1">
              <label style="font-size:10px;color:#86868b;display:flex;justify-content:space-between;align-items:center;margin-bottom:2px"><span>Tamaño en categorías/tarjetas</span><span class="color-scale-val" style="font-weight:700;color:#1d1d1f">100%</span></label>
              <input class="color-scale" type="range" min="50" max="250" step="5" value="100" style="width:100%;accent-color:#1d1d1f" oninput="this.closest('.color-variant-row').querySelector('.color-scale-val').textContent=this.value+'%';updateColorImgPreview(this.closest('.color-variant-row'), this.closest('.color-variant-row').querySelector('.color-img-url')?.value||'')">
            </div>
            <div style="grid-column:1 / -1">
