async function uploadSwatchImg(input){
  if(!input.files||!input.files[0]) return;
  const row=input.closest('.color-variant-row');
  const preview=row.querySelector('.color-swatch-preview');
  const reader=new FileReader();
  reader.onload=e=>{
    preview.innerHTML=`<img src="${e.target.result}" class="color-thumb-img">`;
    row.querySelector('.color-swatch-url').value=e.target.result;
  };
  reader.readAsDataURL(input.files[0]);
  const fd=new FormData();fd.append('image',input.files[0]);
  const res=await fetch('/api/upload',{method:'POST',headers:{'Authorization':'Bearer '+TOKEN},body:fd});
  if(res.ok){const d=await res.json();row.querySelector('.color-swatch-url').value=d.url;preview.innerHTML=`<img src="${d.url}" class="color-thumb-img">`;}
}

async function uploadProdImg(input){
  if(!input.files||!input.files[0]) return;
  const row=input.closest('.color-variant-row');
  const reader=new FileReader();
  reader.onload=e=>{row.querySelector('.color-img-url').value=e.target.result;updateColorImgPreview(row,e.target.result);};
  reader.readAsDataURL(input.files[0]);
  const fd=new FormData();fd.append('image',input.files[0]);
  const res=await fetch('/api/upload',{method:'POST',headers:{'Authorization':'Bearer '+TOKEN},body:fd});
  if(res.ok){const d=await res.json();row.querySelector('.color-img-url').value=d.url;updateColorImgPreview(row,d.url);}
}

function updateColorImgPreview(row,url){
  const fit=row.querySelector('.color-fit')?.value||'contain';
  const pos=row.querySelector('.color-pos')?.value||'center';
  const scale=(parseInt(row.querySelector('.color-scale')?.value)||100)/100;
  let box=row.querySelector('.color-img-preview-box');
  if(!box){
    box=document.createElement('div');box.className='color-img-preview-box';
    box.style.cssText='display:flex;gap:8px;align-items:center;background:#fff;border-radius:8px;padding:8px;border:1px solid #e8e8ed;margin-top:4px';
    box.innerHTML='<img src="" style="width:56px;height:56px;border-radius:6px;background:#f5f5f7;flex-shrink:0;object-fit:contain;object-position:center;transform:scale(1);transform-origin:center center">';
    row.querySelector('div[style*="flex:1"]').appendChild(box);
  }
  const img=box.querySelector('img');
  img.style.display = '';
  img.src=url||'';
  img.style.objectFit=fit;
  img.style.objectPosition=pos;
  img.style.transform=`scale(${scale})`;
  img.style.transformOrigin='center center';
}

// ── IMAGEN PRINCIPAL ──────────────────────────────────────────────────────
function prevMainImg(input){
  if(!input.files||!input.files[0]) return;
  const reader=new FileReader();
  reader.onload=e=>{
    const prev=document.getElementById('mainImgPreview');
    let thumb=document.getElementById('mainImgThumb');
    if(!thumb){
      prev.innerHTML='';
      thumb=document.createElement('img');thumb.id='mainImgThumb';
      prev.appendChild(thumb);
    }
    const scale=(parseInt(document.getElementById('fImgScale')?.value)||100)/100;
    const fit=document.getElementById('fImgFit')?.value||'contain';
    const pos=document.getElementById('fImgPos')?.value||'center';
    thumb.style.cssText=`width:100%;height:100%;object-fit:${fit};object-position:${pos};transform:scale(${scale});transform-origin:center center;transition:transform .2s`;
    thumb.src=e.target.result;
    document.getElementById('fImgUrl').value='';
  };
  reader.readAsDataURL(input.files[0]);
}
function prevMainImgUrl(url){
  let thumb=document.getElementById('mainImgThumb');
  if(!url.trim()) return;
  const prev=document.getElementById('mainImgPreview');
  if(!thumb){
    prev.innerHTML='';
    thumb=document.createElement('img');thumb.id='mainImgThumb';
    const scale=(parseInt(document.getElementById('fImgScale')?.value)||100)/100;
    const fit=document.getElementById('fImgFit')?.value||'contain';
    const pos=document.getElementById('fImgPos')?.value||'center';
    thumb.style.cssText=`width:100%;height:100%;object-fit:${fit};object-position:${pos};transform:scale(${scale});transform-origin:center center`;
    prev.appendChild(thumb);
  }
  thumb.src=url.trim();
}
function applyMainImgStyle(){
  const thumb=document.getElementById('mainImgThumb');
  if(!thumb) return;
  const fit=document.getElementById('fImgFit').value;
  const pos=document.getElementById('fImgPos').value;
  const scale=(parseInt(document.getElementById('fImgScale')?.value)||100)/100;
  thumb.style.objectFit=fit;
  thumb.style.objectPosition=pos;
  thumb.style.transform=`scale(${scale})`;
  thumb.style.transformOrigin='center center';
}


document.addEventListener('DOMContentLoaded', ()=>{
  applyMainImgStyle();
  document.querySelectorAll('.color-variant-row').forEach(row=>{
    const scaleInput=row.querySelector('.color-scale');
    const scaleVal=row.querySelector('.color-scale-val');
    if(scaleInput && scaleVal) scaleVal.textContent = scaleInput.value + '%';
    const detailScaleInput=row.querySelector('.color-detail-scale');
    const detailScaleVal=row.querySelector('.color-detail-scale-val');
    if(detailScaleInput && detailScaleVal) detailScaleVal.textContent = detailScaleInput.value + '%';
    updateColorImgPreview(row, row.querySelector('.color-img-url')?.value||'');
  });
});

// ── GUARDAR ───────────────────────────────────────────────────────────────
async function saveProduct(){
  const name=document.getElementById('fName').value.trim();
  const price=document.getElementById('fPrice').value;
  if(!name||price===''||price===null||price===undefined){flash('Nombre y precio son requeridos','error');return;}

  const specs={};
  document.querySelectorAll('.spec-r').forEach(r=>{
    const k=r.querySelector('.spec-key')?.value.trim();
    const v=r.querySelector('.spec-val')?.value.trim();
    if(k&&v) specs[k]=v;
  });

  const variants=[];
  document.querySelectorAll('.variant-row').forEach(row=>{
    const label=row.querySelector('.variant-label')?.value.trim();
    const price=row.querySelector('.variant-price')?.value;
    const stock=row.querySelector('.variant-stock')?.value;
    if(label) variants.push({label,price:parseFloat(price)||0,stock:parseInt(stock)||0});
  });

  const logos=[];
  document.querySelectorAll('.logo-row-item').forEach(row=>{
    const label=row.querySelector('.logo-label')?.value.trim();
    const img=row.querySelector('.logo-img-url')?.value.trim();
    const link=row.querySelector('.logo-link')?.value.trim();
    if(label||img) logos.push({label:label||'',image_url:img||'',link:link||''});
  });

  const colors=[];
  document.querySelectorAll('.color-variant-row').forEach(row=>{
    const name=row.querySelector('.color-name')?.value.trim();
    const img=row.querySelector('.color-img-url')?.value.trim();
    const swatch=row.querySelector('.color-swatch-url')?.value.trim();
    const fit=row.querySelector('.color-fit')?.value||'contain';
    const pos=row.querySelector('.color-pos')?.value||'center';
    const scale=(parseInt(row.querySelector('.color-scale')?.value)||100)/100;
    const detailScale=(parseInt(row.querySelector('.color-detail-scale')?.value)||100)/100;
    const caps=[...row.querySelectorAll('.color-cap-check:checked')].map(cb=>cb.value);
    const enabled=row.querySelector('.color-enabled') ? row.querySelector('.color-enabled').checked : true;
    if(name||img) colors.push({name:name||'',image_url:img||swatch||'',swatch_url:swatch||img||'',img_fit:fit,img_pos:pos,img_scale:scale,detail_img_scale:detailScale,available_caps:caps,enabled});
  });

  const fd=new FormData();
  fd.append('name',name);
  fd.append('description',document.getElementById('fDesc').value);
  fd.append('price',price);
  fd.append('original_price',document.getElementById('fOrig').value);
  fd.append('category',document.getElementById('fCat').value);
  fd.append('badge',document.getElementById('fBadge').value);
  fd.append('stock',document.getElementById('fStock').value);
  fd.append('sort_order',document.getElementById('fOrder').value);
  fd.append('featured',document.getElementById('fFeatured').checked?'1':'0');
  fd.append('active',document.getElementById('fActive').checked?'1':'0');
  fd.append('enable_installments',document.getElementById('fInstallments') && document.getElementById('fInstallments').checked ? '1' : '0');
  fd.append('specs',JSON.stringify(specs));
  // Ficha técnica — siempre guardar aunque esté oculta
  const ficha = {
    modelo:   document.getElementById('fch_modelo')?.value.trim()||'',
    marca:    document.getElementById('fch_marca')?.value.trim()||'',
    capacidad:document.getElementById('fch_capacidad')?.value.trim()||'',
    colores:  document.getElementById('fch_colores')?.value.trim()||'',
    pantalla: document.getElementById('fch_pantalla')?.value.trim()||'',
    chip:     document.getElementById('fch_chip')?.value.trim()||'',
    ram:      document.getElementById('fch_ram')?.value.trim()||'',
    camara:   document.getElementById('fch_camara')?.value.trim()||'',
    frontal:  document.getElementById('fch_frontal')?.value.trim()||'',
    bateria:  document.getElementById('fch_bateria')?.value.trim()||'',
    so:       document.getElementById('fch_so')?.value.trim()||'',
    conect:   document.getElementById('fch_conect')?.value.trim()||'',
    dim:      document.getElementById('fch_dim')?.value.trim()||'',
    peso:     document.getElementById('fch_peso')?.value.trim()||'',
    resist:   document.getElementById('fch_resist')?.value.trim()||'',
    garantia: document.getElementById('fch_garantia')?.value.trim()||'',
    caja:     document.getElementById('fch_caja')?.value.trim()||'',
    notas:    document.getElementById('fch_notas')?.value.trim()||'',
  };
  fd.append('ficha', JSON.stringify(ficha));
  fd.append('variants',JSON.stringify(variants));
  fd.append('logos',JSON.stringify(logos));
  fd.append('color_variants',JSON.stringify(colors));
  fd.append('img_fit',document.getElementById('fImgFit').value);
  fd.append('img_pos',document.getElementById('fImgPos').value);
  fd.append('img_scale',(parseInt(document.getElementById('fImgScale')?.value)||100)/100);
  fd.append('detail_img_scale',(parseInt(document.getElementById('fDetailImgScale')?.value)||100)/100);

  const imgFile=document.getElementById('imgFile');
  if(imgFile.files&&imgFile.files[0]) fd.append('image',imgFile.files[0]);
  else fd.append('image_url',document.getElementById('fImgUrl').value);

  const id=PRODUCT_ID;
  const url=id?'/api/products/'+id:'/api/products';
  const method=id?'PUT':'POST';
  const btn=document.getElementById('saveBtn');
  btn.disabled=true;btn.textContent='Guardando…';

  try{
    const res=await fetch(url,{method,headers:{'Authorization':'Bearer '+TOKEN},body:fd});
    const data=await res.json();
    if(res.ok){flash('Guardado ✓');setTimeout(()=>location.href='/admin/productos',900);}
    else flash(data.error||'Error al guardar','error');
  }catch(e){flash('Error de conexión','error');}
  btn.disabled=false;btn.textContent='Guardar producto';
}

function flash(msg,type='ok'){
  const el=document.createElement('div');
  el.style.cssText=`position:fixed;bottom:22px;left:50%;transform:translateX(-50%);background:${type==='error'?'#c0392b':'#1d1d1f'};color:#fff;padding:11px 22px;border-radius:10px;font-size:14px;z-index:9999;box-shadow:0 4px 20px rgba(0,0,0,.2);white-space:nowrap`;
  el.textContent=msg;document.body.appendChild(el);setTimeout(()=>el.remove(),3000);
}
</script>
</body></html>
