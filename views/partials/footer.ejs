<footer>
  <div class="inner">
    <div class="footer-grid">
      <div>
        <div class="footer-brand" style="color:#1d1d1f">Mac<span style="color:#1d1d1f">Store</span></div>
        <div class="footer-tagline"><%= settings.store_tagline||'Reseller Apple Autorizado' %><br><%= settings.store_address||'' %></div>
        <% if(settings.store_whatsapp){ %><a href="https://wa.me/<%= settings.store_whatsapp %>" style="display:inline-flex;align-items:center;gap:7px;background:#25d366;color:#fff;padding:9px 18px;border-radius:20px;font-size:13px;font-weight:600"><svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>WhatsApp</a><% } %>
      </div>
      <div class="footer-col">
        <h4>Productos</h4>
        <% (categories||[]).slice(0,6).forEach(c=>{ %><a href="/categoria/<%= c.slug %>"><%= c.name %></a><% }) %>
      </div>
      <% const footerCols = settings.footer_cols || [{title:'Soporte',links:'Financiamiento|#\nGarantía Apple|#\nEnvíos|#\nContacto|#'}]; %>
      <% footerCols.forEach(col=>{ %>
      <div class="footer-col">
        <h4><%=col.title%></h4>
        <% (col.links||'').split('\n').filter(l=>l.trim()).forEach(l=>{ const parts=l.split('|'); %>
        <a href="<%=parts[1]?parts[1].trim():'#'%>"><%=parts[0].trim()%></a>
        <% }) %>
      </div>
      <% }) %>
      <div class="footer-col">
        <h4>Contacto</h4>
        <% if(settings.store_phone){ %><a href="tel:<%= settings.store_phone %>"><%= settings.store_phone %></a><% } %>
        <% if(settings.store_email){ %><a href="mailto:<%= settings.store_email %>"><%= settings.store_email %></a><% } %>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© <%= new Date().getFullYear() %> <%= settings.store_name||'MacStore' %>. Todos los derechos reservados.</span>
      <div class="footer-social">
        <% if(settings.footer_instagram){ %><a href="<%= settings.footer_instagram %>" target="_blank" rel="noopener"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></a><% } %>
        <% if(settings.footer_facebook){ %><a href="<%= settings.footer_facebook %>" target="_blank" rel="noopener"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a><% } %>
      </div>
    </div>
  </div>
</footer>
<% if(settings.store_whatsapp){ %><a href="https://wa.me/<%= settings.store_whatsapp %>" class="whatsapp-fab" target="_blank"><svg width="26" height="26" viewBox="0 0 24 24" fill="#fff"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg></a><% } %>
<script src="/js/macstore.js"></script>
<script src="/js/quotation.js"></script>
</body></html>
