<footer>
  <div class="inner">
    <div class="footer-grid">

      <!-- COLUMNA IZQUIERDA: marca + info -->
      <div class="footer-left">
        <% if(settings.logo_url){ %>
        <div class="footer-logo"><img src="<%=settings.logo_url%>" style="height:32px;object-fit:contain" onerror="this.style.display='none'"></div>
        <% } else { %>
        <div class="footer-brand">Mac<span>Store</span></div>
        <% } %>

        <% if(settings.footer_about||settings.store_tagline){ %>
        <p class="footer-tagline"><%=settings.footer_about||settings.store_tagline%></p>
        <% } %>

        <% if(settings.store_address){ %>
        <div class="footer-info-block">
          <div class="footer-info-label">Dirección</div>
          <div class="footer-info-text"><%=settings.store_address%></div>
        </div>
        <% } %>

        <% if(settings.store_phone||settings.store_email){ %>
        <div class="footer-info-block">
          <div class="footer-info-label">Contacto</div>
          <% if(settings.store_phone){ %><a href="tel:<%=settings.store_phone%>" class="footer-contact-link"><%=settings.store_phone%></a><% } %>
          <% if(settings.store_email){ %><a href="mailto:<%=settings.store_email%>" class="footer-contact-link"><%=settings.store_email%></a><% } %>
        </div>
        <% } %>

        <div class="footer-actions">
          <% if(settings.store_whatsapp){ %>
          <a href="https://wa.me/<%=settings.store_whatsapp%>" class="footer-wa-btn" target="_blank">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <% } %>
          <% const hasSocial = settings.footer_instagram||settings.footer_facebook||settings.footer_tiktok||settings.footer_youtube||settings.footer_twitter; %>
          <% if(hasSocial){ %>
          <div class="footer-social">
            <% if(settings.footer_instagram){ %><a href="<%=settings.footer_instagram%>" target="_blank" rel="noopener" title="Instagram"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></a><% } %>
            <% if(settings.footer_facebook){ %><a href="<%=settings.footer_facebook%>" target="_blank" rel="noopener" title="Facebook"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a><% } %>
            <% if(settings.footer_tiktok){ %><a href="<%=settings.footer_tiktok%>" target="_blank" rel="noopener" title="TikTok"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/></svg></a><% } %>
            <% if(settings.footer_youtube){ %><a href="<%=settings.footer_youtube%>" target="_blank" rel="noopener" title="YouTube"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></a><% } %>
            <% if(settings.footer_twitter){ %><a href="<%=settings.footer_twitter%>" target="_blank" rel="noopener" title="X / Twitter"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.745l7.73-8.835L1.254 2.25H8.08l4.259 5.622L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/></svg></a><% } %>
          </div>
          <% } %>
        </div>
      </div>

      <!-- COLUMNAS DERECHA: links -->
      <div class="footer-cols-grid">
        <div class="footer-col">
          <h4>Productos</h4>
          <% (categories||[]).slice(0,6).forEach(c=>{ %><a href="/categoria/<%=c.slug%>"><%=c.name%></a><% }) %>
        </div>
        <% const footerCols = settings.footer_cols || [{title:'Soporte',links:'Financiamiento|#\nGarantía Apple|#\nEnvíos|#\nContacto|#'}]; %>
        <% footerCols.forEach(col=>{ %>
        <div class="footer-col">
          <h4><%=col.title%></h4>
          <% (col.links||'').split('\n').filter(l=>l.trim()).forEach(l=>{ const p=l.split('|'); %>
          <a href="<%=p[1]?p[1].trim():'#'%>"><%=p[0].trim()%></a>
          <% }) %>
        </div>
        <% }) %>
      </div>

    </div>
    <div class="footer-bottom">
      <span>© <%=new Date().getFullYear()%> <%=settings.store_name||'MacStore'%>. Todos los derechos reservados.</span>
    </div>
  </div>
</footer>
<% if(settings.store_whatsapp){ %><a href="https://wa.me/<%=settings.store_whatsapp%>" class="whatsapp-fab" target="_blank"><svg width="26" height="26" viewBox="0 0 24 24" fill="#fff"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg></a><% } %>
<script src="/js/macstore.js"></script>
<script src="/js/quotation.js"></script>
</body></html>
