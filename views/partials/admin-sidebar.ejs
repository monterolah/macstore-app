<%# views/partials/admin-sidebar.ejs %>
<aside class="admin-sidebar">
  <div class="sidebar-group">
    <div class="sidebar-group-label">Principal</div>
    <a href="/admin" class="sidebar-link <%= page==='dashboard' ? 'active' : '' %>">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      Dashboard
    </a>
  </div>
  <div class="sidebar-group">
    <div class="sidebar-group-label">Catálogo</div>
    <a href="/admin/productos" class="sidebar-link <%= page==='products' ? 'active' : '' %>">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
