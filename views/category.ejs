<%- include('partials/header', {title:product.name, description:product.description}) %>

<style>
  .product-page {
    padding: 44px 22px 80px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .product-layout {
    display: grid !important;
    grid-template-columns: 1fr 1fr !important;
    gap: 52px !important;
    align-items: start !important;
  }
  .product-media {
    position: sticky !important;
    top: 90px !important;
  }
  .product-installments-grid {
    display: grid !important;
    grid-template-columns: 1fr 1fr !important;
    gap: 10px !important;
  }
  .product-specs-grid {
    display: grid !important;
    grid-template-columns: 1fr 1fr !important;
    gap: 8px !important;
    margin-bottom: 24px !important;
  }
  .product-related-grid {
    display: grid !important;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)) !important;
    gap: 18px !important;
  }
  @media (max-width: 900px) {
    .product-page { padding: 32px 16px 64px; }
    .product-layout { grid-template-columns: 1fr !important; gap: 24px !important; }
    .product-media { position: static !important; top: auto !important; }
  }
  @media (max-width: 640px) {
    .product-page { padding: 24px 14px 56px; }
    .product-installments-grid, .product-specs-grid { grid-template-columns: 1fr !important; }
    .product-related-grid { grid-template-columns: 1fr !important; gap: 14px !important; }
    .product-cta-row { display: flex !important; flex-direction: column !important; gap: 10px !important; margin: 18px 0 24px !important; }
    .product-cta-row a { width: 100%; justify-content: center; }
  }
  .variant-btn { transition: all 0.2s ease; }
  .variant-btn:hover:not(:disabled) { border-color: #1d1d1f !important; }
</style>

<div class="product-page">
  <div style="display:flex;gap:5px;font-size:13px;color:#86868b;margin-bottom:24px;flex-wrap:wrap;align-items:center">
    <a href="/" style="color:#86868b;transition:color .2s" onmouseover="this.style.color='#1d1d1f'" onmouseout="this.style.color='#86868b'">MacStore</a>
    <span style="margin:0 3px">/</span>
    <% if(product.category){ %>
      <% const _cat = (categories||[]).find(c=>c.slug===product.category); %>
      <a href="/categoria/<%=product.category%>" style="color:#86868b;transition:color .2s" onmouseover="this.style.color='#1d1d1f'" onmouseout="this.style.color='#86868b'"><%=_cat?_cat.name:product.category%></a><span style="margin:0 3px">/</span>
    <% } %>
    <span style="color:#1d1d1f"><%=product.name%></span>
  </div>

  <div class="product-layout">
    <div class="product-media">
      <div style="position:relative;display:flex;align-items:center;justify-content:center;padding:24px;aspect-ratio:4/5;overflow:hidden;border-radius:32px">
        <div id="productGlow" style="position:absolute;inset:18%;border-radius:50%;background:radial-gradient(ellipse at center, rgba(120,120,200,.22) 0%, rgba(100,180,255,.12) 40%, transparent 70%);filter:blur(28px);pointer-events:none;z-index:0;animation:productGlowPulse 3s ease-in-out infinite;"></div>
        
        <% const colors = (product.color_variants || []).filter(c => c); %>
        <% const activeColors = colors.filter(c => c.enabled !== false); %>
        <% const initialColor = activeColors.length ? activeColors[0] : (colors.length ? colors[0] : null); %>
        <% const initialCaps = initialColor && Array.isArray(initialColor.available_caps) && initialColor.available_caps.length ? initialColor.available_caps : (product.variants||[]).map(v=>v.label); %>
        
        <div class="detail-img-box" style="position:relative;z-index:1;width:100%;height:100%;max-height:480px;transform-origin:center center;transition:opacity .4s ease,transform .4s ease">
          <% const mSrc = initialColor&&initialColor.image_url ? initialColor.image_url : (product.image_url||'');
             const isVid = String(mSrc).match(/\.(mp4|webm|ogg|mov)$/i); 
             const cScale = initialColor && (initialColor.detail_img_scale || initialColor.img_scale) ? (initialColor.detail_img_scale || initialColor.img_scale) : (product.detail_img_scale || product.img_scale || 1); %>
          <img id="mainImg" src="<%=mSrc%>" alt="<%=product.name%>" style="display:<%=isVid?'none':'block'%>;width:100%;height:100%;object-fit:<%=initialColor&&initialColor.img_fit ? initialColor.img_fit : (product.img_fit||'contain')%>;object-position:<%=initialColor&&initialColor.img_pos ? initialColor.img_pos : (p.img_pos||'center')%>;transform:scale(<%=cScale%>);transform-origin:center center;transition:transform 0.4s ease, opacity 0.4s ease" onerror="this.style.display='none'">
          <video id="mainVid" src="<%=mSrc%>" style="display:<%=isVid?'block':'none'%>;width:100%;height:100%;object-fit:contain;transform:scale(<%=cScale%>);transform-origin:center center;transition:transform 0.4s ease, opacity 0.4s ease" autoplay loop muted playsinline></video>
        </div>
      </div>

      <div id="galleryContainer" style="display:<%=initialColor&&(initialColor.gallery&&initialColor.gallery.length>0)?'flex':'none'%>;gap:16px;margin-top:24px;justify-content:center;overflow-x:auto">
        <% if(initialColor) {
           const gArr = [initialColor.image_url, ...(initialColor.gallery||[])].filter(Boolean);
           if(gArr.length > 1) {
             gArr.forEach((gUrl, idx) => { %>
               <button onclick="changeColor('<%=gUrl%>', window._selectedColor || '', '<%=initialColor.img_fit||'contain'%>', '<%=initialColor.img_pos||'center'%>', <%=cScale%>); document.querySelectorAll('.gal-thumb').forEach(b=>b.style.borderColor='transparent'); this.style.borderColor='#0071e3'" class="gal-thumb" style="width:64px;height:64px;border-radius:12px;border:2px solid <%=idx===0?'#0071e3':'transparent'%>;background:#f5f5f7;padding:4px;cursor:pointer;flex-shrink:0;transition:border-color .2s">
                 <img src="<%=gUrl%>" style="width:100%;height:100%;object-fit:cover;border-radius:6px" onerror="this.style.display='none'">
               </button>
             <% });
           }
        } %>
      </div>

      <% if(colors.length){ %>
      <div style="text-align:center;margin-top:20px">
        <p id="colorLabel" style="font-size:14px;color:#1d1d1f;font-weight:500;margin-bottom:14px;min-height:20px;letter-spacing:-.01em"><%=colors[0]&&colors[0].name?colors[0].name:''%></p>
        <div style="display:flex;gap:18px;justify-content:center;flex-wrap:wrap;padding:2px 4px">
          <% colors.forEach((c,i)=>{ %>
            <button onclick="selectColor(this,this.dataset.img,this.dataset.name,this.dataset.fit,this.dataset.pos,this.dataset.scale,JSON.parse(decodeURIComponent(this.dataset.caps||'%5B%5D')), JSON.parse(decodeURIComponent(this.dataset.gallery||'%5B%5D')))"
              data-img="<%=c.image_url||c.swatch_url||''%>" data-name="<%=c.name||''%>" data-fit="<%=c.img_fit||'contain'%>" data-pos="<%=c.img_pos||'center'%>" data-scale="<%=c.detail_img_scale || c.img_scale || 1%>"
              data-caps="<%=encodeURIComponent(JSON.stringify(c.available_caps||[]))%>" data-gallery="<%=encodeURIComponent(JSON.stringify(c.gallery||[]))%>"
              title="<%=c.name%>" class="color-swatch <%=i===0?'active':''%>"
              style="width:48px;height:48px;border-radius:50%;border:none;padding:0;cursor:pointer;background:transparent;box-shadow:<%=i===0?'0 0 0 3px rgba(0,113,227,.22)':'0 0 0 1px rgba(0,0,0,.08)'%>;position:relative;flex-shrink:0;transition:all 0.2s;">
              <img src="<%=c.swatch_url||c.image_url%>" alt="<%=c.name%>" style="width:48px;height:48px;border-radius:50%;object-fit:cover;display:block;">
            </button>
          <% }) %>
        </div>
      </div>
      <% } %>
    </div>

    <div>
      <% if(product.category){ %><% const _cl = (categories||[]).find(c=>c.slug===product.category); %><p style="font-size:12px;color:#86868b;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px;font-weight:600"><%=_cl?_cl.name:product.category%></p><% } %>
      <% if(product.badge){ %><span style="display:inline-flex;background:#1d1d1f;color:#fff;font-size:11px;font-weight:600;padding:4px 12px;border-radius:20px;margin-bottom:12px;"><%=product.badge%></span><% } %>
      
      <h1 style="font-size:clamp(28px,3.8vw,44px);font-weight:700;letter-spacing:-.048em;margin-bottom:10px"><%=product.name%></h1>
      <p style="font-size:17px;color:#86868b;line-height:1.5;margin-bottom:22px"><%=product.description%></p>

      <div style="font-size:32px;font-weight:700;letter-spacing:-.04em;margin-bottom:4px" id="mainPrice"><%=formatPrice(product.price)%></div>
      <div id="mainOrigPrice" style="font-size:16px;color:#86868b;text-decoration:line-through;margin-bottom:18px;display:<%=product.original_price ? 'block' : 'none'%>">
        <%=product.original_price ? formatPrice(product.original_price) : ''%>
      </div>

      <% const variants = product.variants || []; %>
      <% if(variants.length){ %>
      <div style="margin:24px 0">
        <div style="font-size:12px;font-weight:700;color:#86868b;text-transform:uppercase;letter-spacing:.04em;margin-bottom:12px">Capacidad</div>
        <div style="display:flex;flex-wrap:wrap;gap:10px">
          <% variants.forEach((v,i)=>{ %>
            <% const vAvail = initialCaps.length===0 || initialCaps.includes(v.label); %>
            <% const vFirst = variants.find(vv => initialCaps.length===0 || initialCaps.includes(vv.label)); %>
            <% const vIsFirst = vFirst && v.label === vFirst.label; %>
            <button onclick="selectVariant(this,'<%=v.label%>',<%=v.price||0%>, <%=v.original_price||'null'%>)"
              class="variant-btn <%=vIsFirst?'variant-active':''%>" <%=!vAvail?'disabled':''%>
              style="padding:12px 20px;border-radius:14px;border:<%=vIsFirst?'2px solid #1d1d1f':'1.5px solid #d2d2d7'%>;background:<%=vIsFirst?'#1d1d1f':'#fff'%>;color:<%=vIsFirst?'#fff':'#1d1d1f'%>;font-size:14px;font-weight:600;cursor:pointer;flex:1;min-width:100px;opacity:<%=vAvail?'1':'0.35'%>">
              <span><%=v.label%></span>
              <% if(v.price){ %><span style="font-size:11px;display:block;opacity:.7"><%=formatPrice(v.price)%></span><% } %>
            </button>
          <% }) %>
        </div>
      </div>
      <% } %>

      <% if(product.stock>0){ %>
      <div style="font-size:13px;color:#1a7f37;font-weight:600;margin:16px 0;display:flex;align-items:center;gap:6px">
        <span style="width:8px;height:8px;border-radius:50%;background:#1a7f37;box-shadow:0 0 0 3px rgba(26,127,55,0.1)"></span>
        En stock — <%=product.stock%> disponibles
      </div>
      <% } %>

      <% if(product.price > 150 && product.enable_installments !== false){ %>
      <div style="background:#f5f5f7;border-radius:18px;padding:20px;margin:24px 0">
        <div style="font-size:12px;color:#86868b;font-weight:700;text-transform:uppercase;margin-bottom:14px">Financiamiento sin intereses</div>
        <div class="product-installments-grid">
          <div style="background:#fff;border-radius:12px;padding:16px;text-align:center;box-shadow:0 2px 8px rgba(0,0,0,0.02)">
            <div style="font-size:11px;color:#86868b;margin-bottom:4px">6 meses</div>
            <div style="font-size:22px;font-weight:700;letter-spacing:-.03em" id="cuota6">$<%=(product.price/6).toFixed(2)%></div>
          </div>
          <div style="background:#fff;border-radius:12px;padding:16px;text-align:center;box-shadow:0 2px 8px rgba(0,0,0,0.02)">
            <div style="font-size:11px;color:#86868b;margin-bottom:4px">10 meses</div>
            <div style="font-size:22px;font-weight:700;letter-spacing:-.03em" id="cuota10">$<%=(product.price/10).toFixed(2)%></div>
          </div>
        </div>
      </div>
      <% } %>

      <div class="product-cta-row" style="display:flex;gap:12px;margin:32px 0">
        <% if(settings.store_whatsapp){ %>
        <a id="buyBtn" href="https://wa.me/<%=settings.store_whatsapp%>?text=Hola%2C%20quiero%20comprar%20<%=encodeURIComponent(product.name)%>%20(<%=encodeURIComponent(formatPrice(product.price))%>)"
           target="_blank"
           style="background:#0071e3;color:#fff;padding:16px 32px;border-radius:980px;font-size:17px;font-weight:600;display:inline-flex;align-items:center;justify-content:center;gap:10px;transition:all .2s;text-decoration:none;flex:1;box-shadow:0 8px 20px rgba(0,113,227,0.15)"
           onmouseover="this.style.background='#005bb5';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='#0071e3';this.style.transform='translateY(0)'">
          Comprar ahora
        </a>
        <% } %>
        <% if(settings.store_phone){ %>
        <a href="tel:<%=settings.store_phone%>" style="background:#fff;color:#0071e3;border:1.5px solid #0071e3;padding:16px 24px;border-radius:980px;font-size:16px;display:inline-flex;align-items:center;gap:8px;transition:all .2s;text-decoration:none;font-weight:600">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.08 6.08l.97-.97a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </a>
        <% } %>
      </div>

      <% const sk = Object.keys(product.specs||{}); %>
      <% if(sk.length){ %>
      <div style="font-size:13px;font-weight:700;margin-bottom:12px;text-transform:uppercase;color:#86868b;letter-spacing:0.05em">Especificaciones</div>
      <div class="product-specs-grid">
        <% sk.forEach(k=>{ %>
        <div style="background:#f5f5f7;border-radius:14px;padding:14px 18px;">
          <div style="font-size:10px;color:#86868b;text-transform:uppercase;margin-bottom:4px;font-weight:600"><%=k%></div>
          <div style="font-size:14px;font-weight:600;color:#1d1d1f"><%=product.specs[k]%></div>
        </div>
        <% }) %>
      </div>
      <% } %>
    </div>
  </div>
</div>

<script>
function selectVariant(btn, label, price, variantOrigPrice){
  // 1. Resetear botones
  document.querySelectorAll('.variant-btn').forEach(b=>{
    b.style.background='#fff';b.style.color='#1d1d1f';
    b.style.border='1.5px solid #d2d2d7';
    b.classList.remove('variant-active');
  });
  // 2. Activar botón clickeado
  btn.style.background='#1d1d1f';btn.style.color='#fff';
  btn.style.border='2px solid #1d1d1f';
  btn.classList.add('variant-active');

  if(price){
    const fmt = (n) => '$' + parseFloat(n).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g,',');
    
    // 3. Actualizar Precio Principal
    document.getElementById('mainPrice').textContent = fmt(price);
    
    // 4. Lógica de Precio Tachado (CORREGIDA)
    const origEl = document.getElementById('mainOrigPrice');
    if(origEl) {
      if(variantOrigPrice && variantOrigPrice > price) {
        origEl.textContent = fmt(variantOrigPrice);
        origEl.style.display = 'block';
      } else {
        // Si no hay precio de oferta en esta variante, ocultamos el tachado
        origEl.style.display = 'none';
      }
    }

    // 5. Actualizar Cuotas
    const c6 = document.getElementById('cuota6');
    const c10 = document.getElementById('cuota10');
    if(c6) c6.textContent = '$'+(price/6).toFixed(2);
    if(c10) c10.textContent = '$'+(price/10).toFixed(2);

    window._selectedPrice = price;
    window._selectedVariant = label;
  }
}

const PRODUCT_DATA = <%- JSON.stringify({
  name: product.name,
  price: product.price,
  original_price: product.original_price||null
}) %>;

function changeColor(src, name, fit, pos, scale) {
  const im = document.getElementById('mainImg');
  const vi = document.getElementById('mainVid');
  const glow = document.getElementById('productGlow');
  const isV = src.match(/\.(mp4|webm|ogg|mov)$/i);
  const targetScale = scale || 1;

  if(im) { im.style.opacity = '0'; im.style.transform = 'scale(' + (targetScale*0.9) + ')'; }
  if(vi) { vi.style.opacity = '0'; vi.style.transform = 'scale(' + (targetScale*0.9) + ')'; }

  setTimeout(() => {
    if(isV) {
      im.style.display='none'; vi.style.display='block'; vi.src=src;
      vi.onloadeddata = () => { vi.style.opacity='1'; vi.style.transform='scale('+targetScale+')'; };
    } else {
      vi.style.display='none'; im.style.display='block'; im.src=src;
      im.style.objectFit=fit||'contain'; im.style.objectPosition=pos||'center';
      im.onload = () => { im.style.opacity='1'; im.style.transform='scale('+targetScale+')'; };
    }
  }, 200);
}

function selectColor(btn, imageUrl, colorName, imgFit, imgPos, imgScale, availCaps, galleryArr=[]) {
  document.querySelectorAll('.color-swatch').forEach(s => {
    s.style.boxShadow = '0 0 0 1px rgba(0,0,0,.08)';
    s.style.transform = 'scale(1)';
  });
  btn.style.boxShadow = '0 0 0 3px rgba(0,113,227,.22)';
  btn.style.transform = 'scale(1.08)';
  if(document.getElementById('colorLabel')) document.getElementById('colorLabel').textContent = colorName||'';
  
  // Filtrar almacenamiento según disponibilidad del color
  const caps = Array.isArray(availCaps) ? availCaps : [];
  document.querySelectorAll('.variant-btn').forEach(vb => {
    const label = vb.querySelector('span').textContent.trim();
    const ok = caps.length===0 || caps.includes(label);
    vb.style.opacity = ok ? '1' : '0.35';
    vb.disabled = !ok;
  });

  if(imageUrl) changeColor(imageUrl, colorName, imgFit, imgPos, imgScale);
}
</script>

<%- include('partials/footer') %>
