<%- include('partials/header', {title: settings.store_name || 'MacStore'}) %>

<%
const heroBanners = banners && banners.length ? banners : [];
const heroProduct = featured && featured[0];
%>

<style>
  /* --- ESTILO APPLE PREMIUM --- */
  .ms-hero-wrap {
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Helvetica Neue", sans-serif;
  }
  .ms-hero-title {
    font-size: clamp(36px, 6vw, 56px) !important;
    font-weight: 700 !important;
    letter-spacing: -0.015em !important;
    line-height: 1.1 !important;
    margin-bottom: 12px;
  }
  .ms-hero-sub {
    font-size: clamp(18px, 3vw, 24px) !important;
    font-weight: 400 !important;
    letter-spacing: 0.008em !important;
    margin-bottom: 24px;
  }
  .ms-eyebrow {
    font-size: 12px !important;
    font-weight: 600 !important;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 8px;
  }
  .ms-btn-primary, .ms-btn-ghost, .ms-btn-outline {
    border-radius: 980px !important;
    padding: 12px 24px !important;
    font-size: 15px !important;
    font-weight: 600 !important;
    transition: all 0.3s ease !important;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .ms-btn-primary {
    background: #0071e3;
    color: #fff;
  }
  .ms-btn-primary:hover {
    background: #0077ed;
    transform: scale(1.02);
  }
  .ms-btn-ghost {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    color: #fff;
  }
  .ms-btn-ghost:hover {
    background: rgba(255, 255, 255, 0.2);
  }
  .ms-btn-outline {
    border: 1px solid #1d1d1f !important;
    color: #1d1d1f !important;
  }

  /* CATÁLOGO Y TARJETAS */
  .ms-section-head {
    text-align: center;
    margin-bottom: 40px;
  }
  .ms-section-head h2 {
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 700;
    letter-spacing: -0.015em;
    color: #1d1d1f;
    margin-bottom: 8px;
  }
  .ms-section-head p {
    font-size: 19px;
    color: #86868b;
  }
  .ms-catalog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
    padding: 32px 0;
  }
  .ms-card {
    background: #fff;
    border-radius: 18px;
    padding: 24px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.04);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border: 1px solid rgba(0,0,0,0.02);
  }
  .ms-card:hover {
    transform: translateY(-4px) scale(1.01);
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
  }
  .ms-card-img {
    height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
  }
  .ms-card-img img {
    transition: transform 0.4s ease;
  }
  .ms-card:hover .ms-card-img img {
    transform: scale(1.05) !important;
  }
  .ms-card-cat {
    font-size: 12px;
    font-weight: 600;
    color: #bf4800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 4px;
  }
  .ms-card-name {
    font-size: 19px;
    font-weight: 600;
    color: #1d1d1f;
    letter-spacing: -0.01em;
    margin-bottom: 8px;
  }
  .ms-card-foot {
    margin-top: auto;
    padding-top: 16px;
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .ms-card-price {
    font-size: 17px;
    font-weight: 600;
    color: #1d1d1f;
  }
  .ms-card-orig {
    font-size: 13px;
    color: #86868b;
    text-decoration: line-through;
  }

  /* SHOWCASES */
  .ms-showcase {
    padding: 80px 24px;
  }
  .ms-showcase-title {
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 700;
    letter-spacing: -0.015em;
    margin-bottom: 12px;
  }
  .ms-showcase-desc {
    font-size: 19px;
    line-height: 1.4;
    margin-bottom: 24px;
  }

  /* SOPORTE */
  .ms-support-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 24px;
    margin-top: 40px;
  }
  .ms-support-card {
    background: #f5f5f7;
    border-radius: 18px;
    padding: 32px 24px;
    text-align: center;
    transition: transform 0.3s ease;
  }
  .ms-support-card:hover {
    transform: translateY(-4px);
  }
  .ms-support-icon {
    font-size: 40px;
    margin-bottom: 16px;
  }
  .ms-support-card h3 {
    font-size: 19px;
    font-weight: 600;
    color: #1d1d1f;
    margin-bottom: 8px;
  }
  .ms-support-card p {
    font-size: 15px;
    color: #515154;
    line-height: 1.4;
  }

  /* PROMOS Y CUOTAS */
  .home-promos-section {
    background: #fff;
    padding: 80px 24px;
  }
  .home-promos-row {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    justify-content: center;
    align-items: stretch;
    margin-top: 40px;
  }
  .home-promos-item {
    text-align: center;
    width: min(280px, 100%);
    background: #f5f5f7;
    border-radius: 18px;
    padding: 32px 24px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .home-promos-item:hover {
    transform: translateY(-4px) !important;
    box-shadow: 0 12px 32px rgba(0,0,0,0.06);
  }
  .home-promos-item img {
    max-height: 90px;
    max-width: 100%;
    object-fit: contain;
    display: block;
    margin: 0 auto;
  }
  .home-cuotas-section {
    background: #f5f5f7;
    padding: 48px 24px;
    border-top: 1px solid #e8e8ed;
  }
  .home-cuotas-row {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: center;
    align-items: center;
  }
  .home-cuotas-item {
    background: #fff;
    border-radius: 14px;
    padding: 12px 20px;
    border: 1px solid #e8e8ed;
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 120px;
    justify-content: center;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .home-cuotas-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.05);
  }

  /* RESPONSIVE */
  @media (max-width: 640px) {
    .home-promos-section,
    .home-cuotas-section {
      padding: 48px 16px;
    }
    .home-promos-row {
      gap: 16px;
      margin-top: 24px;
    }
    .home-promos-item {
      width: 100%;
      max-width: 320px;
      padding: 24px 16px;
    }
    .home-promos-item img {
      max-height: 72px;
    }
    .home-cuotas-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .home-cuotas-item {
      min-width: 0;
      width: 100%;
      padding: 10px 12px;
    }
    .ms-catalog-grid {
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    .ms-card {
      padding: 16px;
    }
    .ms-card-img {
      height: 160px;
    }
  }
  @media (max-width: 420px) {
    .ms-catalog-grid {
      grid-template-columns: 1fr;
    }
    .home-cuotas-row {
      grid-template-columns: 1fr;
    }
  }

  /* Ajuste específico para banners del hero en móvil */
  @media (max-width: 768px) {
    .ms-hero-wrap {
      height: clamp(460px, 78svh, 760px) !important;
      min-height: 460px !important;
    }
    .ms-slide.hero-banner-slide,
    .ms-slide.hero-banner-slide.active {
      min-height: 100% !important;
      height: 100% !important;
    }
    .ms-slide.hero-banner-slide {
      background: #000 !important;
    }
    .ms-slide.hero-banner-slide .ms-hero-bg {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
      object-position: center center !important;
      transform: scale(1.01) !important;
      background: #000;
    }
    .ms-slide.hero-banner-slide.active .ms-hero-bg {
      transform: scale(1) !important;
    }
    .ms-slide.hero-banner-slide .ms-hero-overlay {
      background: linear-gradient(to bottom, rgba(0, 0, 0, 0.18) 0, rgba(0, 0, 0, 0.52) 100%);
    }
    .ms-slide.hero-banner-slide .ms-hero-content {
      max-width: 100%;
      padding: 0 16px 20px;
    }
  }
</style>

<!-- ══ HERO — full screen con imagen de fondo ══ -->
<section class="ms-hero-wrap">
  <% if(heroBanners.length){ %>
    <% heroBanners.forEach((b,i)=>{ %>
    <div class="ms-slide hero-banner-slide <%=i===0?'active':''%>" style="background:<%=b.bg_color||'#000'%>">
      <% if(b.image_url){ %>
      <img class="ms-hero-bg" src="<%=b.image_url%>" alt="<%=b.title%>" loading="<%=i===0?'eager':'lazy'%>">
      <% } %>
      <div class="ms-hero-overlay"></div>
      <div class="ms-hero-content">
        <% if(b.subtitle){ %><p class="ms-eyebrow" style="color:<%=b.text_color||'#fff'%>;opacity:.75"><%=b.subtitle%></p><% } %>
        <% if(b.title){ %><h1 class="ms-hero-title" style="color:<%=b.text_color||'#fff'%>"><%=b.title%></h1><% } %>
        <div class="ms-hero-btns">
          <% if(b.cta_url){ %><a href="<%=b.cta_url%>" class="ms-btn-primary"><%=b.cta_text||'Más información'%></a><% } %>
          <a href="/productos" class="ms-btn-ghost">Ver catálogo</a>
        </div>
      </div>
    </div>
    <% }) %>
    <% if(heroBanners.length > 1){ %>
    <div class="ms-dots">
      <% heroBanners.forEach((_,i)=>{ %><button class="ms-dot" aria-label="Slide <%=i+1%>"></button><% }) %>
    </div>
    <% } %>
  <% } else if(heroProduct){ %>
    <div class="ms-slide active" style="background:#1d1d1f">
      <% if(heroProduct.image_url){ %>
      <img class="ms-hero-bg" src="<%=heroProduct.image_url%>" alt="<%=heroProduct.name%>" loading="eager">
      <% } %>
      <div class="ms-hero-overlay"></div>
      <div class="ms-hero-content">
        <p class="ms-eyebrow" style="color:rgba(255,255,255,.7)">Disponible ahora</p>
        <h1 class="ms-hero-title" style="color:#fff"><%=heroProduct.name%></h1>
        <p class="ms-hero-sub" style="color:rgba(255,255,255,.85)"><%=heroProduct.description%></p>
        <div class="ms-hero-btns">
          <a href="/producto/<%=heroProduct.slug%>" class="ms-btn-primary">Más información</a>
          <a href="/productos" class="ms-btn-ghost">Ver catálogo</a>
        </div>
      </div>
    </div>
  <% } else { %>
    <div class="ms-slide active" style="background:#1d1d1f">
      <div class="ms-hero-overlay" style="background:rgba(0,0,0,.3)"></div>
      <div class="ms-hero-content">
        <% if(settings.auth_hero_badge_active!==false){ %>
        <p class="ms-eyebrow" style="color:rgba(255,255,255,.7)">Distribuidor Autorizado Apple</p>
        <% } %>
        <h1 class="ms-hero-title" style="color:#fff">MacStore</h1>
        <p class="ms-hero-sub" style="color:rgba(255,255,255,.8)">Tecnología Apple original en El Salvador</p>
        <div class="ms-hero-btns">
          <a href="/productos" class="ms-btn-primary">Ver productos</a>
        </div>
      </div>
    </div>
  <% } %>
</section>

<!-- ══ SHOWCASES ══ -->
<%
const slugOrder = ['mac','iphone','ipad','apple-watch','airpods'];
const catMap = {};
(categories||[]).forEach(c => catMap[c.slug] = c);
const prodByCat = {};
(featured||[]).forEach(p => { if(!prodByCat[p.cat_slug||p.category]) prodByCat[p.cat_slug||p.category] = p; });
%>

<% slugOrder.forEach((slug,i)=>{
  const cat  = catMap[slug];
  const prod = prodByCat[slug];
  if(!cat && !prod) return;
  const dark    = i % 2 !== 0;
  const reverse = i % 2 !== 0;
  const showcaseImg = (prod && prod.image_url) ? prod.image_url : (cat && cat.image_url) ? cat.image_url : null;
%>
<section class="ms-showcase <%=dark?'ms-dark':'ms-light'%>" data-reveal data-delay="<%=i*60%>" style="<%=cat&&cat.bg_color&&!dark?'background:'+cat.bg_color:''%>">
  <div class="ms-showcase-inner ms-showcase-horiz <%=reverse?'ms-showcase-reverse':''%>">

    <!-- TEXTO -->
    <div class="ms-showcase-text">
      <% if(prod){ %><p class="ms-eyebrow" style="color:<%=dark?'rgba(255,255,255,.45)':'#86868b'%>"><%=cat?cat.name:''%></p><% } %>
      <h2 class="ms-showcase-title" style="color:<%=dark?'#fff':'#1d1d1f'%>"><%=prod?prod.name:(cat?cat.name:'')%></h2>
      <p class="ms-showcase-desc" style="color:<%=dark?'rgba(255,255,255,.65)':'#515154'%>"><%=prod?prod.description:''%></p>
      <div class="ms-showcase-btns" style="justify-content:flex-start">
        <% if(prod){ %>
        <a href="/producto/<%=prod.slug%>" class="ms-btn-primary" style="<%=dark?'background:#fff;color:#1d1d1f':''%>">Más información</a>
        <a href="/categoria/<%=slug%>" class="ms-btn-outline" style="<%=dark?'border-color:rgba(255,255,255,.4);color:#fff':''%>">Ver modelos</a>
        <% } else { %>
        <a href="/categoria/<%=slug%>" class="ms-btn-primary" style="<%=dark?'background:#fff;color:#1d1d1f':''%>">Ver <%=cat?cat.name:slug%></a>
        <% } %>
      </div>
    </div>

    <!-- IMAGEN -->
    <% if(showcaseImg){ %>
    <div class="ms-showcase-img">
      <img src="<%=showcaseImg%>" alt="<%=prod?prod.name:(cat?cat.name:'')%>" loading="lazy" onerror="this.parentNode.style.display='none'">
    </div>
    <% } %>

  </div>
</section>
<% }) %>

<!-- ══ CATÁLOGO ══ -->
<section class="ms-catalog-section" id="catalogo">
  <div class="ms-inner">
    <div class="ms-section-head" data-reveal>
      <h2>Catálogo MacStore</h2>
      <p>Productos Apple originales con garantía oficial</p>
    </div>
    <div class="ms-catalog-grid">
      <% (featured||[]).forEach((p,i)=>{ %>
      <a href="/producto/<%=p.slug%>" class="ms-card" data-reveal data-delay="<%=i*80%>">
        <% const cardColors = Array.isArray(p.color_variants) ? p.color_variants.filter(c=>c && c.enabled !== false) : []; %>
        <% const firstCardColor = cardColors.length ? cardColors[0] : null; %>
        <div class="ms-card-img" style="--img-scale:<%=firstCardColor&&firstCardColor.img_scale ? firstCardColor.img_scale : (p.img_scale||1)%>">
          <% if(p.badge){ %><span class="ms-card-badge"><%=p.badge%></span><% } %>
          <div class="ms-card-glow"></div>
          <% const hpid = (p.id||p.slug||'').replace(/[^a-z0-9]/gi,''); %>
          <img id="cardimg_<%=hpid%>" src="<%=firstCardColor&&firstCardColor.image_url ? firstCardColor.image_url : (p.image_url||'')%>" alt="<%=p.name%>" loading="lazy" style="object-fit:<%=firstCardColor&&firstCardColor.img_fit ? firstCardColor.img_fit : (p.img_fit||'contain')%>;object-position:<%=firstCardColor&&firstCardColor.img_pos ? firstCardColor.img_pos : (p.img_pos||'center')%>;transform:scale(<%=firstCardColor&&firstCardColor.img_scale ? firstCardColor.img_scale : (p.img_scale||1)%>);transform-origin:center center" onerror="this.style.display='none'">
        </div>
        <div class="ms-card-body">
          <p class="ms-card-cat"><%=p.cat_name||p.category||''%></p>
          <h3 class="ms-card-name"><%=p.name%></h3>
          <% const cardAllCaps = Array.isArray(p.variants) ? p.variants.map(v=>v.label).filter(Boolean) : []; %>
          <% if(cardColors.length){ %>
          <div class="ms-card-swatches">
            <% cardColors.slice(0,5).forEach((c,ci)=>{
              const sw = c.swatch_url||c.image_url||'';
              const img = c.image_url||p.image_url||'';
              const caps = Array.isArray(c.available_caps)&&c.available_caps.length ? c.available_caps : cardAllCaps;
              if(!sw) return;
            %>
            <span class="ms-card-swatch <%=ci===0?'active':''%>"
              style="background-image:url('<%=sw%>')"
              title="<%=c.name||''%>"
              onclick="(function(el,e){e.preventDefault();e.stopPropagation();swatchClick(el,'<%=hpid%>','<%=img%>',<%=JSON.stringify(caps)%>,'<%=c.img_fit||p.img_fit||'contain'%>','<%=c.img_pos||p.img_pos||'center'%>','<%=c.img_scale||p.img_scale||1%>')})(this,event)"
            ></span>
            <% }) %>
            <% if(cardColors.length>5){ %><span class="ms-card-swatch-more">+<%=cardColors.length-5%></span><% } %>
          </div>
          <% } %>
          <% if(cardAllCaps.length){ %>
          <div id="caps_<%=hpid%>" style="display:flex;flex-wrap:wrap;gap:4px;margin-top:4px">
            <% const hFirstCaps = cardColors.length&&Array.isArray(cardColors[0].available_caps)&&cardColors[0].available_caps.length ? cardColors[0].available_caps : cardAllCaps; %>
            <% cardAllCaps.forEach(cap=>{ const active=hFirstCaps.includes(cap); %>
            <span data-cap="<%=cap%>" style="font-size:10px;border:1px solid <%=active?'#d2d2d7':'#e8e8ed'%>;border-radius:5px;padding:1px 6px;color:<%=active?'#515154':'#c0c0c0'%>;text-decoration:<%=active?'none':'line-through'%>"><%=cap%></span>
            <% }) %>
          </div>
          <% } %>
          <% if((p.price||0) > 150 && p.enable_installments !== false){ %>
          <div style="margin:8px 0 4px">
            <div style="font-size:12px;color:#86868b">10 cuotas de: <strong style="color:#1d1d1f">$<%=(p.price/10).toFixed(2)%></strong></div>
            <div style="font-size:12px;color:#86868b">6 cuotas de: <strong style="color:#1d1d1f">$<%=(p.price/6).toFixed(2)%></strong></div>
          </div>
          <% } %>
          <div class="ms-card-foot">
            <span class="ms-card-price"><%=formatPrice(p.price)%></span>
            <% if(p.original_price){ %><span class="ms-card-orig"><%=formatPrice(p.original_price)%></span><% } %>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
    <div style="text-align:center;margin-top:48px" data-reveal>
      <a href="/productos" class="ms-btn-primary">Ver catálogo completo</a>
    </div>
  </div>
</section>

<!-- ══ DISTRIBUIDOR AUTORIZADO ══ -->
<% if(settings.auth_section_active!==false){ %>
<section class="ms-auth-section" data-reveal style="background:#f5f5f7; border-radius: 24px; padding: 48px 24px; margin: 40px auto; max-width: 1200px; text-align: center;">
  <div class="ms-inner ms-auth-inner" style="display: flex; flex-direction: column; align-items: center; gap: 24px;">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 814 1000" class="ms-auth-apple" style="width: 56px; height: 56px; fill: #1d1d1f;"><path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76 0-103.7 40.8-165.9 40.8s-105-42.3-150.3-109.2c-49.1-72.4-92.7-187.5-92.7-278.8 0-167.5 108.9-256.2 215.7-256.2 65.3 0 120 43.5 162.1 43.5 40.3 0 103.1-45.8 174.4-45.8zm-169.3-126.8c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"/></svg>
    <div>
      <h2 style="font-size: clamp(24px, 4vw, 36px); font-weight: 700; color: #1d1d1f; letter-spacing: -0.015em; margin-bottom: 12px;"><%=settings.auth_title||'Distribuidor Autorizado Apple'%></h2>
      <p style="font-size: 17px; color: #515154; max-width: 600px; margin: 0 auto; line-height: 1.5;"><%=settings.auth_desc||'Productos 100% originales con garantía oficial Apple. Servicio certificado en El Salvador.'%></p>
    </div>
  </div>
</section>
<% } %>

<!-- ══ SOPORTE ══ -->
<% if(settings.support_section_active!==false){ %>
<section class="ms-catalog-section" id="soporte" style="background:#fff">
  <div class="ms-inner">
    <div class="ms-section-head" data-reveal>
      <h2><%=settings.support_title||'Soporte'%></h2>
      <p><%=settings.support_subtitle||'Asistencia y acompañamiento para tus dispositivos Apple'%></p>
    </div>
    <div class="ms-support-grid">
      <% const supCards = settings.support_cards || [{icon:'⚙️',title:'Configuración inicial',desc:'Te ayudamos a poner en marcha tu equipo.'},{icon:'📦',title:'Migración de datos',desc:'Pasamos tu información al ecosistema Apple.'},{icon:'💬',title:'Asesoría personalizada',desc:'Resolvemos dudas sobre compatibilidad y uso.'}]; %>
      <% supCards.forEach((s,i)=>{ %>
      <div class="ms-support-card" data-reveal data-delay="<%=i*100%>">
        <div class="ms-support-icon"><%=s.icon%></div>
        <h3><%=s.title%></h3>
        <p><%=s.desc%></p>
      </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- ══ ANUNCIOS / PROMOCIONES ══ -->
<% if(announcements && announcements.length){ %>
<section class="home-promos-section">
  <div class="ms-inner">
    <div class="ms-section-head" data-reveal>
      <h2>Promociones y financiamiento</h2>
      <p>Facilidades de pago y ofertas exclusivas</p>
    </div>
    <div class="home-promos-row" data-stagger>
      <% announcements.forEach(a=>{ %>
      <% if(a.link){ %><a href="<%=a.link%>" style="display:block; text-decoration: none;" data-reveal class="home-promos-item"><% } else { %><div data-reveal class="home-promos-item"><% } %>
        <% if(a.image_url){ %>
        <img src="<%=a.image_url%>" alt="<%=a.title||'Anuncio'%>" onerror="this.style.display='none'">
        <% } %>
        <% if(a.title){ %><div style="font-size:15px;color:#1d1d1f;margin-top:16px;font-weight:600"><%=a.title%></div><% } %>
      <% if(a.link){ %></a><% } else { %></div><% } %>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<%- include('partials/footer') %>

<% if(settings && settings.cuotas_active !== false && settings.cuota_logos && settings.cuota_logos.length){ %>
<section class="home-cuotas-section">
  <div class="ms-inner">
    <div style="text-align:center;margin-bottom:24px">
      <div style="font-size:12px;font-weight:600;color:#86868b;text-transform:uppercase;letter-spacing:.1em">Cuotas sin intereses con</div>
    </div>
    <div class="home-cuotas-row">
      <% settings.cuota_logos.forEach(l=>{ %>
      <div class="home-cuotas-item">
        <% if(l.logo_url){ %>
        <img src="<%=l.logo_url%>" alt="<%=l.name||''%>" style="height:28px;max-width:72px;object-fit:contain" onerror="this.style.display='none'">
        <% } %>
        <% if(l.name){ %><span style="font-size:13px;font-weight:600;color:#1d1d1f"><%=l.name%></span><% } %>
      </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>
