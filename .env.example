# ── App ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Seguridad ────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
SESSION_SECRET=cambia_esto_por_otro_secreto_diferente

# ── Admin ────────────────────────────────────────────────
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=TuPasswordSegura123!

# ── Firebase ─────────────────────────────────────────────
# En producción (Railway/Render): pega aquí el contenido de serviceAccountKey.json como string JSON
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Bucket de Firebase Storage (lo encuentras en Firebase Console > Storage)
# Formato: tu-proyecto.firebasestorage.app  o  tu-proyecto.appspot.com
FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app

# ── Gemini API (Ramiro) ──────────────────────────────────
GEMINI_API_KEY=tu_api_key_de_google

# ── Cloudinary (imágenes) ────────────────────────────────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── SSL local (solo red local — en hosting déjalo vacío) ─
# Si existen ssl/key.pem y ssl/cert.pem, el servidor arranca en HTTPS automáticamente
# HTTPS_PORT=3443
# LOCAL_IP=192.168.1.244

# Crear datos demo solo en desarrollo
SEED_DEMO=false
